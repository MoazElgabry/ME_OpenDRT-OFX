{
  "pluginId": "me-opendrt",
  "displayName": "ME_OpenDRT",
  "releaseRepo": "MoazElgabry/ME_OpenDRT-OFX",
  "minManagerVersion": "0.1.0",
  "hostProcesses": [
    "Resolve",
    "DaVinci Resolve",
    "Fusion",
    "Fusion Studio",
    "Nuke",
    "NukeX",
    "NukeStudio",
    "Hiero"
  ],
  "requiredFamilies": [
    "windows",
    "macos",
    "linux"
  ],
  "availableStableMarker": "manager-available-stable",
  "versionPattern": "(?:^|-)v(?<version>.+)$",
  "assetRules": [
    {
      "family": "windows",
      "platform": "windows",
      "arch": "x86_64",
      "assetPattern": "^ME_OpenDRT_.*Windows.*portable\\.zip$",
      "packageType": "zip",
      "bundleName": "ME_OpenDRT.ofx.bundle",
      "bundleIdentifier": "com.moazelgabry.me-opendrt",
      "installPath": "C:\\Program Files\\Common Files\\OFX\\Plugins"
    },
    {
      "family": "macos",
      "platform": "macos",
      "arch": "universal",
      "assetPattern": "^ME_OpenDRT_.*macOS_universal.*portable\\.zip$",
      "packageType": "zip",
      "bundleName": "ME_OpenDRT.ofx.bundle",
      "bundleIdentifier": "com.meplugins.ME_OpenDRT",
      "installPath": "/Library/OFX/Plugins"
    },
    {
      "family": "macos",
      "platform": "macos",
      "arch": "aarch64",
      "assetPattern": "^ME_OpenDRT_.*macOS_arm64.*portable\\.zip$",
      "packageType": "zip",
      "bundleName": "ME_OpenDRT.ofx.bundle",
      "bundleIdentifier": "com.meplugins.ME_OpenDRT",
      "installPath": "/Library/OFX/Plugins"
    },
    {
      "family": "macos",
      "platform": "macos",
      "arch": "x86_64",
      "assetPattern": "^ME_OpenDRT_.*macOS_x86_64.*portable\\.zip$",
      "packageType": "zip",
      "bundleName": "ME_OpenDRT.ofx.bundle",
      "bundleIdentifier": "com.meplugins.ME_OpenDRT",
      "installPath": "/Library/OFX/Plugins"
    },
    {
      "family": "linux",
      "platform": "linux",
      "arch": "x86_64",
      "assetPattern": "^ME_OpenDRT_.*linux_x86_64_cuda_opencl.*portable\\.tar\\.gz$",
      "packageType": "tar.gz",
      "bundleName": "ME_OpenDRT.ofx.bundle",
      "bundleIdentifier": "com.moazelgabry.me-opendrt",
      "installPath": "/usr/OFX/Plugins"
    }
  ]
}
